BOT_TOKEN=123456:your_token
ADMIN_IDS=123456789

BOT_MODE=polling
DATA_DIR=bot/data
ROOT_NODE_ID=start
MAX_HISTORY=20

POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/botdb
REDIS_URL=redis://redis:6379/0

WEBHOOK_BASE_URL=https://example.com
WEBHOOK_PATH=/webhook/telegram
WEBHOOK_SECRET_TOKEN=change-me
WEBHOOK_LISTEN_HOST=0.0.0.0
WEBHOOK_LISTEN_PORT=8080

BROADCAST_BATCH_SIZE=100
BROADCAST_RPS=20
BROADCAST_RETRY_LIMIT=3

TZ=Europe/Moscow
LOG_LEVEL=INFO
